rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperadmin() {
      return isSignedIn() && hasUserDoc() && myRole() == 'superadmin';
    }

    function isSocioOrUp() {
      return isSignedIn() && hasUserDoc() && myRole() in ['socio', 'superadmin'];
    }

    function isVendedorOrUp() {
      return isSignedIn() && hasUserDoc() && myRole() in ['vendedor', 'socio', 'superadmin'];
    }

    function isContador() {
      return isSignedIn() && hasUserDoc() && myRole() == 'contador';
    }

    // ===== users =====
    match /users/{uid} {
      // Cada uno lee su doc; socio/superadmin pueden ver todos.
      allow read: if isSignedIn() && (request.auth.uid == uid || isSocioOrUp());

      // Primer ingreso: el usuario crea SU propio doc, solo con rol 'cliente'.
      // (El bootstrap de superadmin/cambios de rol se hace desde consola
      //  o por un superadmin existente — ver allow update.)
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'cliente';

      // El propio usuario puede actualizar SOLO datos básicos (no su rol ni
      // campos arbitrarios): lista blanca de campos editables.
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'photoURL', 'email']);

      // Solo superadmin asigna/cambia roles y administra usuarios.
      allow write: if isSuperadmin();
    }

    // ===== products =====
    // Lectura PÚBLICA (precios de venta, stock, destacados).
    // Escritura solo superadmin. precioCosto NO se guarda acá — va en productCosts/{id}
    match /products/{id} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    // ===== promociones ===== (banner destacado del catálogo)
    // Lectura PÚBLICA (las muestra el catálogo). Escritura solo superadmin.
    match /promociones/{id} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    // ===== productCosts (info sensible: precio costo) =====
    // Solo socio/superadmin pueden leerlo. Vendedor y público no ven precio costo.
    match /productCosts/{id} {
      allow read: if isSocioOrUp();
      allow write: if isSuperadmin();
    }

    // ===== clientes ===== (CRM: lo usan vendedores y socios)
    match /clientes/{id} {
      allow read, create, update: if isVendedorOrUp();
      allow delete: if isSocioOrUp();
    }

    // ===== orders ===== (pedidos web/vendedor)
    match /orders/{id} {
      // El que crea el pedido debe ser el dueño (createdBy) y el total un número.
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.total is number;
      allow read, update, delete: if isVendedorOrUp();
    }

    // ===== Reportes: camiones, cheques, gastos, cajas ===== (gestión interna)
    match /trucks/{id}         { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    match /checks/{id}         { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    match /expenses/{id}       { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    match /cashClosings/{id}   { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    // Cuentas corrientes: compras a proveedores (deudas) y pagos
    match /proveedores/{id}      { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    match /purchases/{id}        { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    match /supplierPayments/{id} { allow read: if isSocioOrUp(); allow write: if isSuperadmin(); }
    // Ventas: remitos (descuentan stock) y facturas
    // El contador también puede LEER remitos y facturas (su área de consulta).
    match /remitos/{id}          { allow read: if isSocioOrUp() || isContador(); allow write: if isSuperadmin(); }
    match /facturas/{id}         { allow read: if isSocioOrUp() || isContador(); allow write: if isSuperadmin(); }

    // Bitácora (auditoría): registro INMUTABLE. La crea quien opera; la leen
    // socio/superadmin (control interno). Nadie la edita ni borra.
    match /bitacora/{id} {
      allow read: if isSocioOrUp();
      allow create: if isVendedorOrUp();
      allow update, delete: if false;
    }
    // Interruptor de servicio: lo lee toda la app (incluso sin login) para
    // habilitar/bloquear; NADIE lo escribe desde la app (solo consola/admin SDK).
    match /config/licencia     { allow read: if true;          allow write: if isSignedIn() && request.auth.token.email == 'axelfaber@gmail.com'; }
    match /config/{id}         { allow read: if isSignedIn();   allow write: if isSuperadmin() && id != 'licencia'; }

    // ===== formularioDatos ===== (configuración inicial, la carga el cliente)
    // Lo llenan Anabela y Luciano SIN estar logueados (todavía no tienen cuenta),
    // así que el create es público. Solo create: nadie lee, edita ni borra desde
    // la app — leerlo es cosa de socio/superadmin.
    // ⚠️ Cuando terminen de cargarlo, cambiar a `allow create: if false` y el
    //    formulario queda cerrado (evita que alguien lo spamee).
    match /formularioDatos/{id} {
      allow create: if request.resource.data.cuit is string
        && request.resource.data.razonSocial is string
        && request.resource.data.email is string
        && request.resource.data.keys().size() <= 40;
      allow read: if isSocioOrUp();
      allow update, delete: if false;
    }

    // Todo lo demás: denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
